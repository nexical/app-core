{
  "name": "@nexical/app-core",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push --accept-data-loss",
    "db:seed": "npx prisma db seed",
    "db:validate": "npx prisma validate",
    "setup:version": "npx tsx scripts/generate-version.ts",
    "setup:theme": "npx tsx scripts/generate-theme.ts",
    "setup:prisma": "npx tsx scripts/generate-prisma.ts",
    "setup:build": "npm run setup:version && npm run setup:theme && npm run setup:prisma",
    "test:unit": "npm run setup:build && npx vitest run -c vitest.unit.config.ts",
    "test:integration": "npm run setup:build && npx vitest run -c vitest.integration.config.ts",
    "test:e2e": "npm run setup:build && npx playwright test",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e"
  },
  "lint-staged": {
    "**/*": [
      "prettier --write --ignore-unknown"
    ],
    "**/*.{js,jsx,ts,tsx,astro}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/node": "^10.0.3",
    "@astrojs/react": "^5.0.1",
    "@hookform/resolvers": "^5.2.2",
    "@nexical/sdk": "*",
    "@panva/hkdf": "^1.2.1",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@prisma/config": "^7.5.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-email/components": "^1.0.10",
    "@react-email/render": "^2.0.4",
    "@scalar/api-reference-react": "^0.9.13",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-table": "^8.21.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.0.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "defu": "^6.1.4",
    "framer-motion": "^12.38.0",
    "globby": "^16.1.1",
    "i18next": "^25.9.0",
    "i18next-http-backend": "^3.0.2",
    "jose": "^6.2.2",
    "lucide-react": "^0.577.0",
    "nodemailer": "^8.0.3",
    "pg": "^8.20.0",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^16.5.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vaul": "^1.1.2",
    "yaml": "^2.8.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nexical/generator": "*",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/nodemailer": "^7.0.11",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fs-extra": "^11.3.4",
    "glob": "^13.0.6",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prisma": "^7.5.0",
    "repomix": "^1.12.0",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  }
}
